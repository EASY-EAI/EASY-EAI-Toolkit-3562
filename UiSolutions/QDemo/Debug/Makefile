####### Install

install_target: first FORCE
	@test -d $(INSTALL_ROOT)/userdata/UiSolu || mkdir -p $(INSTALL_ROOT)/userdata/UiSolu
	$(QINSTALL_PROGRAM) ../Release/$(QMAKE_TARGET) $(INSTALL_ROOT)/userdata/UiSolu/$(QMAKE_TARGET)

uninstall_target: FORCE
	-$(DEL_FILE) $(INSTALL_ROOT)/userdata/UiSolu/$(QMAKE_TARGET)
	-$(DEL_DIR) $(INSTALL_ROOT)/userdata/UiSolu/ 


install: install_target  FORCE

uninstall: uninstall_target  FORCE

